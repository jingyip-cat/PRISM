.pytest_cache/
.coverage
.coverage.*
htmlcov/
.cache/
.mypy_cache/
.ruff_cache/

# ───────────────────────────────────────────────────────────────
# Experiment artifacts (do NOT commit — regenerated by the eval scripts)
# ───────────────────────────────────────────────────────────────
# Evaluation outputs
scripts/eval/results/
scripts/eval/results_*/
scripts/eval/reports/
scripts/eval/analytics/

# Ingest checkpoints (graph.json, faiss/, chunks.json, etc.)
scripts/eval/checkpoints/
scripts/eval/checkpoints_*/

# Benchmark data downloaded at runtime (auto-fetched by run_locomo.py)
scripts/eval/data/

# Diagnostics
scripts/diagnostics/

# Logs and scratch
logs/
tmp/
*.log

# Runtime memory artifacts
data/
*.faiss
faiss/
graph.json
chunks.json
pipeline_state.json

